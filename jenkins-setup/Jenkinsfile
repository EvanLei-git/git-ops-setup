pipeline {
    agent any

    triggers {
        // Poll GitHub every 1 minute (since we don't have a public IP for webhooks)
        pollSCM('* * * * *')
    }

    environment {
        // Adjust these as needed for your project
        REPO_URL = "https://github.com/EvanLei-git/argocd-examples.git"
        GIT_CREDS_ID = "git-token" // Required to push back to GitHub
    }

    stages {
        stage('Setup Tools') {
            steps {
                // Install kustomize to validate the manifests
                sh 'curl -s "https://raw.githubusercontent.com/kubernetes-sigs/kustomize/master/hack/install_kustomize.sh" | bash'
            }
        }
        
        stage('Check Build (CI)') {
            steps {
                echo 'Running CI tests: Validating Kubernetes manifests...'
                // Check if the base and overlays can build successfully without errors
                sh './kustomize build examples/base > /dev/null'
                sh './kustomize build examples/overlays/dev > /dev/null'
                echo 'Build check passed successfully!'
            }
        }
        
        stage('Promote to CD (Merge)') {
            steps {
                echo 'CI passed! Merging kustomize into dev-build branch for ArgoCD to deploy...'
                withCredentials([usernamePassword(credentialsId: "${GIT_CREDS_ID}", usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                    sh '''
                        # Configure git
                        git config user.name "Jenkins CI"
                        git config user.email "ci@jenkins.local"
                        
                        # Push the current tested commit directly to the dev-build branch
                        git push https://${GIT_USER}:${GIT_PASS}@github.com/EvanLei-git/argocd-examples.git HEAD:dev-build
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo 'CI Pipeline Succeeded. ArgoCD will now detect the changes and test/sync the deployment automatically.'
        }
        failure {
            echo 'CI Pipeline Failed. Please fix the manifest errors before ArgoCD deploys them.'
        }
    }
}