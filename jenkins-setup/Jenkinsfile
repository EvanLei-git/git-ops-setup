pipeline {
    agent any

    options {
        // Stop Jenkins from downloading the 'git-ops-setup' repo
        skipDefaultCheckout()
    }

    triggers {
        // Poll GitHub every 1 minute (since we don't have a public IP for webhooks)
        pollSCM('* * * * *')
    }

    environment {
        APP_REPO_URL = "https://github.com/EvanLei-git/argocd-kustomize-examples.git"
        GIT_CREDS_ID = "git-token" 
        
        // Auto-incrementing build tag
        BUILD_TAG = "testbuild-v0.0.${BUILD_NUMBER}"
    }

    stages {
        stage('Prepare Workspace & Clone') {
            steps {
                // 1. Wipe the workspace completely clean
                deleteDir() 
                
                // 2. Clone the repo immediately while the folder is perfectly empty!
                withCredentials([usernamePassword(credentialsId: "${GIT_CREDS_ID}", usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                    sh 'git clone -b kustomize https://${GIT_USER}:${GIT_PASS}@github.com/EvanLei-git/argocd-kustomize-examples.git .'
                }
            }
        }

        stage('Install Kustomize') {
            steps {
                // 3. Now that the repo is downloaded, we can safely drop the kustomize tool into the root folder
                sh 'curl -s "https://raw.githubusercontent.com/kubernetes-sigs/kustomize/master/hack/install_kustomize.sh" | bash'
            }
        }

        stage('Inject GitOps Build Tag') {
            steps {
                dir('examples/overlays/dev') {
                    // --without-selector. This flag tells Kustomize: "Add this label to the pods so ArgoCD can track the new build, but leave the immutable Deployment selectors alone!"
                    sh "\"${WORKSPACE}/kustomize\" edit add label build-version:${BUILD_TAG} --force --without-selector"
                }
            }
        }
        
        stage('Check Build (CI)') {
            steps {
                echo "Validating Kubernetes manifests with new tag: ${BUILD_TAG}..."
                
                sh "\"${WORKSPACE}/kustomize\" build examples/base > /dev/null"
                sh "\"${WORKSPACE}/kustomize\" build examples/overlays/dev > /dev/null"
                
                echo 'Build check passed successfully!'
            }
        }
        
        stage('Update Manifests (GitOps Push)') {
            steps {
                echo 'CI passed! Committing the new tag and pushing directly back to the kustomize branch...'
                withCredentials([usernamePassword(credentialsId: "${GIT_CREDS_ID}", usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                    sh '''
                        git config user.name "Jenkins CI"
                        git config user.email "ci@jenkins.local"
                        
                        git commit -am "chore: update dev build tag to ${BUILD_TAG} [skip ci]"
                        git push https://${GIT_USER}:${GIT_PASS}@github.com/EvanLei-git/argocd-kustomize-examples.git HEAD:kustomize
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo "CI Pipeline Succeeded! Tag ${BUILD_TAG} was pushed to the kustomize branch."
        }
        failure {
            echo 'CI Pipeline Failed. The broken YAML was NOT pushed to GitHub.'
        }
    }
}